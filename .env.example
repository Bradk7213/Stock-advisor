# ============================================================
# Stock Advisor - Environment Variables Template
# Copy this file to .env.local and fill in your values.
# Add all of these to Vercel → Settings → Environment Variables.
# ============================================================

# --- Supabase (Database) ---
# Get from: https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Stock Data APIs ---
# Finnhub: https://finnhub.io → Dashboard → API Key
FINNHUB_API_KEY=your-finnhub-api-key

# Alpha Vantage: https://www.alphavantage.co → Get Free API Key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# --- AI Analysis ---
# Anthropic: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Auth Secrets (generate random 30+ char strings) ---
# Tip: run `openssl rand -base64 32` to generate each one
JWT_SECRET=replace-with-random-30-char-string
NEXTAUTH_SECRET=replace-with-random-30-char-string
NEXTAUTH_URL=https://your-vercel-project-url.vercel.app

# --- Cron Job Security ---
# Used to authenticate Vercel cron job requests
CRON_SECRET=replace-with-random-30-char-string

# --- Notifications (Optional) ---
# Microsoft Teams webhook URL (from Teams → Connectors → Incoming Webhook)
TEAMS_WEBHOOK_URL=

# Email — choose one:
# SendGrid: https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=

# Resend: https://resend.com → API Keys (unlimited free tier)
RESEND_API_KEY=
